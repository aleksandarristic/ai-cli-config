{
  "autoAccept": true,
  "shell": {
    "allowRedirection": true,
    "allowPiping": true,
    "allowHeredoc": true,
    "allowChaining": true
  },
  "tools": {
    "core": [
      "run_shell_command(echo)",
      "run_shell_command(git)",
      "run_shell_command(ln)",
      "run_shell_command(find)",
      "run_shell_command(cat)",
      "run_shell_command(printf)",
      "run_shell_command(pytest)",
      "run_shell_command(./.venv/bin/pytest)",
      "write_file",
      "read_file",
      "run_shell_command"
    ],
    "exclude": [
      "run_shell_command(git push)",
      "run_shell_command(rm -rf *)"
    ]
  }
}
